{
  "deepseek": {
    "repository": "model-clis/deepseek",
    "description": "Stateless DeepSeek subagent CLI",
    "homepage": "https://github.com/model-clis/deepseek",
    "license": "MIT",
    "assets": {
      "homebrew": "deepseek-macos-aarch64",
      "scoop": "deepseek-windows-x86_64.exe"
    }
  },
  "kimi-code": {
    "repository": "MoonshotAI/kimi-code",
    "description": "AI coding agent for your terminal",
    "homepage": "https://github.com/MoonshotAI/kimi-code",
    "license": "MIT",
    "tag_prefix": "@moonshot-ai/kimi-code@",
    "scoop_bin_source": "kimi.exe",
    "scoop_bin_name": "kimi",
    "checkver": {
      "url": "https://api.github.com/repos/MoonshotAI/kimi-code/releases",
      "regex": "@moonshot-ai/kimi-code@([\\d.]+)"
    },
    "assets": {
      "scoop": {
        "64bit": "kimi-code-win32-x64.zip",
        "arm64": "kimi-code-win32-arm64.zip"
      }
    }
  }
}
